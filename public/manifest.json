{
  "manifest_version": 3,
  "name": "ChitChats Assistant",
  "version": "0.6.0",
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://chitchats.com/clients/*/shipments*"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "downloads"]
}
